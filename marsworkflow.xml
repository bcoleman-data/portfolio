          <mxGeometry x="1180" y="180" width="260" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="arrow8" edge="1" parent="1" source="flask" target="dashboard"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
